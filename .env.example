# ------------------------------------------------------------------------------
# TaskFlow API — environment variables
# Copy this file to `.env` and fill in real values before starting the server.
# ------------------------------------------------------------------------------

# Connection string for the Prisma datasource. Any database Prisma supports
# works; the schema targets PostgreSQL by default.
# Example:  postgresql://user:password@localhost:5432/taskflow?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"

# Secret used to sign JWTs. Use a long, random, high-entropy value
# (e.g. `openssl rand -base64 48`). Never commit the real value.
JWT_SECRET=replace_me_with_a_long_random_secret

# HTTP port the Express server listens on.
PORT=3000

# Runtime mode: development | production | test
NODE_ENV=development
